# ─────────── realtime service (services/realtime — Railway) ───────────
PORT=2567
# Railway Postgres + Redis plugins inject these; local: docker or a dev instance
DATABASE_URL=postgresql://quivo:quivo@localhost:5432/quivo
REDIS_URL=redis://localhost:6379

# ─────────── Solana / MagicBlock ───────────
SOLANA_RPC=https://api.devnet.solana.com
# ER endpoint is resolved at runtime from the router (getDelegationStatus).
# Set only to force a specific ephemeral validator (demo insurance against public RPC).
EPHEMERAL_RPC=
QUIVO_PROGRAM_ID=
# Prize mint: real devnet USDC, or a self-minted 6-dp "test USDC" you control (demo-safe).
POT_MINT=
# Fee-payer / relayer secret (base58). SERVER ONLY — never ships to a client.
RELAYER_SECRET=

# ─────────── stage app (apps/stage — Vercel, NEXT_PUBLIC_* only) ───────────
NEXT_PUBLIC_REALTIME_URL=ws://localhost:2567
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
